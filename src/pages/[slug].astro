---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import CtaButton from "../components/CtaButton.astro";
import ChromeGlyph from "../components/ChromeGlyph.astro";
import ScreenshotFrame from "../components/ScreenshotFrame.astro";
import { JOURNEYS, getJourney } from "../data/journeys";
import { SITE_NAME, withBase } from "../consts";

export function getStaticPaths() {
  return JOURNEYS.map((j) => ({ params: { slug: j.slug } }));
}

const { slug } = Astro.params;
const j = getJourney(slug!)!;
const idx = JOURNEYS.findIndex((x) => x.slug === slug);
const prev = idx > 0 ? JOURNEYS[idx - 1] : null;
const next = idx < JOURNEYS.length - 1 ? JOURNEYS[idx + 1] : null;

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: j.faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://jobs.splander.com" },
    { "@type": "ListItem", position: 2, name: j.nav, item: `https://jobs.splander.com/${j.slug}` },
  ],
};
---

<Base
  title={j.metaTitle}
  description={j.metaDescription}
  path={`/${j.slug}`}
  jsonLd={[faqLd, breadcrumbLd]}
>
  <!-- HERO -->
  <section class="band-plum text-white">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-16 lg:grid-cols-2 lg:py-24">
      <div>
        <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-wider text-emerald-200">
          <span class="tnum rounded-full bg-white/10 px-2.5 py-1 ring-1 ring-white/15">
            Step {j.step} of {JOURNEYS.length}
          </span>
          <span>{j.eyebrow}</span>
        </div>
        <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.08] tracking-tight sm:text-5xl">
          {j.title}
        </h1>
        <p class="mt-5 max-w-lg text-lg leading-relaxed text-slate-300">{j.subtitle}</p>
        <div class="mt-8">
          <CtaButton size="lg">
            <ChromeGlyph slot="icon" size={20} />
            Add to Chrome — it's free
          </CtaButton>
        </div>
      </div>
      <ScreenshotFrame label={j.heroShot} ratio="16/11" />
    </div>
  </section>

  <!-- INTRO -->
  <Section tone="cream">
    <p class="mx-auto max-w-3xl text-center text-xl leading-relaxed text-slate-700">
      {j.intro}
    </p>
  </Section>

  <!-- FEATURES (alternating) -->
  <Section tone="white">
    <div class="space-y-16 lg:space-y-24">
      {
        j.features.map((f, i) => (
          <div class="grid items-center gap-10 lg:grid-cols-2">
            <div class={i % 2 === 1 ? "lg:order-2" : ""}>
              <h2 class="font-display text-2xl font-extrabold text-slate-900 sm:text-3xl">{f.title}</h2>
              <p class="mt-4 text-base leading-relaxed text-slate-600">{f.body}</p>
            </div>
            <div class={i % 2 === 1 ? "lg:order-1" : ""}>
              <ScreenshotFrame label={f.shot ?? "Screenshot coming soon"} />
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- FAQ -->
  <Section tone="slate">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-3xl font-extrabold text-slate-900">Questions, answered</h2>
      <dl class="mt-8 divide-y divide-slate-200">
        {
          j.faqs.map((f) => (
            <div class="py-5">
              <dt class="font-semibold text-slate-900">{f.q}</dt>
              <dd class="mt-2 text-slate-600">{f.a}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </Section>

  <!-- PREV / NEXT -->
  <Section tone="white">
    <div class="grid gap-4 sm:grid-cols-2">
      {
        prev ? (
          <a href={withBase(prev.slug)} class="group rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-frame">
            <span class="text-xs font-bold uppercase tracking-wider text-slate-400">← Previous · Step {prev.step}</span>
            <h3 class="mt-2 font-display text-lg font-bold text-slate-900">{prev.title}</h3>
          </a>
        ) : <div class="hidden sm:block" />
      }
      {
        next && (
          <a href={withBase(next.slug)} class="group rounded-2xl border border-slate-100 bg-white p-6 text-right shadow-sm transition-all hover:-translate-y-1 hover:shadow-frame sm:col-start-2">
            <span class="text-xs font-bold uppercase tracking-wider text-green">Next · Step {next.step} →</span>
            <h3 class="mt-2 font-display text-lg font-bold text-slate-900">{next.title}</h3>
          </a>
        )
      }
    </div>
  </Section>

  <!-- CTA -->
  <section class="band-plum text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl font-extrabold sm:text-4xl">Track your whole hunt with {SITE_NAME}</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">Free, private, and ready in under a minute.</p>
      <div class="mt-8 flex justify-center">
        <CtaButton size="lg">
          <ChromeGlyph slot="icon" size={20} />
          Add to Chrome
        </CtaButton>
      </div>
    </div>
  </section>
</Base>
