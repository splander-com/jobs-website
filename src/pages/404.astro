---
import Base from "../layouts/Base.astro";
import CtaButton from "../components/CtaButton.astro";
import { JOURNEYS } from "../data/journeys";
---

<Base title="Page not found" description="That page doesn't exist." noindex={true}>
  <section class="band-plum text-white">
    <div class="mx-auto max-w-2xl px-5 py-24 text-center">
      <p class="font-display text-6xl font-extrabold text-lime">404</p>
      <h1 class="mt-4 font-display text-3xl font-extrabold">This page wandered off.</h1>
      <p class="mt-3 text-slate-300">Let's get you back to your job hunt.</p>
      <div class="mt-8 flex justify-center">
        <CtaButton href="/" variant="ghost-light" size="lg" external={false}>Back to home</CtaButton>
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-2 text-sm">
        {JOURNEYS.map((j) => (
          <a href={`/${j.slug}`} class="rounded-full bg-white/10 px-3 py-1 text-slate-200 ring-1 ring-white/15 transition-colors hover:bg-white/15">{j.nav}</a>
        ))}
      </div>
    </div>
  </section>
</Base>
