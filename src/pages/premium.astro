---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import CtaButton from "../components/CtaButton.astro";
import ChromeGlyph from "../components/ChromeGlyph.astro";

const free = [
  "Status badges on every job listing",
  "Private side-panel tracker, funnel & streak",
  "Gmail auto-status (read-only, opt-in)",
  "CV-to-job match score (on-device)",
  "LinkedIn profile import & score",
  "One-click ATS autofill",
  "Recruiter CRM & editable outreach templates",
];
const premium = [
  "Cloud sync across all your devices",
  "AI-quality CV-to-job match & tailored suggestions",
  "AI LinkedIn profile scoring",
  "AI-drafted recruiter outreach, per contact",
  "First access to everything new",
];
---

<Base
  title="Premium"
  description="Splander Jobs is free forever. Premium adds cloud sync across devices and AI-quality CV matching, profile scoring and recruiter outreach. Join the waitlist from inside the extension."
  path="/premium"
>
  <section class="band-plum text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center lg:py-20">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-emerald-200 ring-1 ring-white/15">Waitlist open</span>
      <h1 class="mt-5 font-display text-4xl font-extrabold tracking-tight sm:text-5xl">Free forever. Premium when you want more.</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">
        The tracker, badges, Gmail auto-updates, match scores, autofill and goals all cost nothing —
        and always will. Premium adds cloud sync and AI across the journey.
      </p>
    </div>
  </section>

  <Section tone="cream">
    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-sm">
        <h2 class="font-display text-2xl font-extrabold text-slate-900">Free</h2>
        <p class="mt-1 text-sm text-slate-500">Everything you need to run your search.</p>
        <ul class="mt-6 space-y-3">
          {free.map((f) => (
            <li class="flex items-start gap-3 text-sm text-slate-700">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="#10B981" class="mt-0.5 shrink-0" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
              {f}
            </li>
          ))}
        </ul>
        <CtaButton size="lg" class="mt-8 w-full">
          <ChromeGlyph slot="icon" size={20} />
          Add to Chrome
        </CtaButton>
      </div>

      <div class="relative rounded-2xl border-2 border-green bg-white p-8 shadow-cta">
        <span class="absolute -top-3 left-8 rounded-full bg-emerald-700 px-3 py-1 text-xs font-bold text-white">Coming soon</span>
        <h2 class="font-display text-2xl font-extrabold text-slate-900">Premium</h2>
        <p class="mt-1 text-sm text-slate-500">Everything in Free, plus cloud &amp; AI.</p>
        <ul class="mt-6 space-y-3">
          {premium.map((f) => (
            <li class="flex items-start gap-3 text-sm text-slate-700">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="#10B981" class="mt-0.5 shrink-0" aria-hidden="true"><path d="M10 1l1.8 4.9L17 7l-4.2 2.4L12 15l-2-4-2 4-.8-5.6L3 7l5.2-1.1L10 1z"/></svg>
              {f}
            </li>
          ))}
        </ul>
        <div class="mt-8 rounded-xl bg-slate-50 p-4 text-sm text-slate-600">
          Join the waitlist from the <span class="font-semibold text-slate-900">Premium</span> tab inside the
          extension — one tap, no commitment, first access when AI features open.
        </div>
      </div>
    </div>
    <p class="mt-8 text-center text-sm text-slate-500">
      Logging in is always optional. It backs up your settings and claims your Premium spot — your job data stays private unless you choose to sync it.
    </p>
  </Section>
</Base>
