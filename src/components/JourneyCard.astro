---
import { withBase } from "../consts";

interface Props {
  index: number;
  slug: string;
  eyebrow: string;
  title: string;
  blurb: string;
}
const { index, slug, eyebrow, title, blurb } = Astro.props;
const num = String(index + 1).padStart(2, "0");
---
<a
  href={withBase(slug)}
  class="group relative flex flex-col rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-frame"
>
  <span aria-hidden="true" class="tnum font-display text-3xl font-extrabold text-slate-200 transition-colors group-hover:text-lime">{num}</span>
  <span class="mt-3 text-xs font-bold uppercase tracking-wider text-emerald-700">{eyebrow}</span>
  <h3 class="mt-1 font-display text-lg font-bold leading-snug text-slate-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{blurb}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-700">
    Explore
    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true"><path fill-rule="evenodd" d="M7.3 4.3a1 1 0 0 1 1.4 0l5 5a1 1 0 0 1 0 1.4l-5 5a1 1 0 0 1-1.4-1.4L11.6 10 7.3 5.7a1 1 0 0 1 0-1.4Z" clip-rule="evenodd"/></svg>
  </span>
</a>
