---
/* 5-bucket semantic palette, mirrored from STATUS_COLORS / marketing.md §5. */
interface Props {
  label: string;
  tone?: "info" | "success" | "warning" | "error" | "neutral";
  glyph?: "check" | "spark" | "none";
}
const { label, tone = "info", glyph = "check" } = Astro.props;
// Darker text tones (xx-700) so the small pill labels clear WCAG AA on tints.
const tones = {
  info: "bg-blue-50 text-blue-700 ring-blue-100",
  success: "bg-emerald-50 text-green-700 ring-emerald-100",
  warning: "bg-amber-50 text-amber-700 ring-amber-100",
  error: "bg-red-50 text-red-700 ring-red-100",
  neutral: "bg-slate-100 text-slate-600 ring-slate-200",
};
---
<span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ring-inset ${tones[tone]}`}>
  {glyph === "check" && (
    <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
  )}
  {glyph === "spark" && (
    <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 1l1.8 4.9L17 7l-4.2 2.4L12 15l-2-4-2 4-.8-5.6L3 7l5.2-1.1L10 1z"/></svg>
  )}
  {label}
</span>
