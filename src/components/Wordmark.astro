---
import Mark from "./Mark.astro";

interface Props {
  size?: number;
  /** "cream" tone for light surfaces, "light" (white text) for the plum band. */
  tone?: "dark" | "light";
  markVariant?: "cream" | "plum" | "light";
  class?: string;
}

const { size = 32, tone = "dark", markVariant, class: cls } = Astro.props;
const textColor = tone === "light" ? "text-white" : "text-slate-900";
const mv = markVariant ?? (tone === "light" ? "plum" : "cream");
const fontSize = Math.round(size * 0.78);
---

<span class={`inline-flex items-baseline gap-2 ${cls ?? ""}`}>
  <span style={`transform: translateY(${Math.round(size * 0.18)}px)`}>
    <Mark size={size} variant={mv} />
  </span>
  <span
    class={`font-display font-extrabold tracking-tight ${textColor}`}
    style={`font-size:${fontSize}px; letter-spacing:-0.03em`}
  >
    Splander <span class="relative">Jobs<span
        class="absolute left-0 -bottom-0.5 h-[3px] w-full rounded-full"
        style="background:#10B981"
        aria-hidden="true"></span></span>
  </span>
</span>
