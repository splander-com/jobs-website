---
import { withBase } from "../consts";
const points = [
  { t: "No account, no signup", d: "Start tracking the moment you install. Nothing to create." },
  { t: "Runs in your browser", d: "Every job you track is saved on your own device (chrome.storage.local)." },
  { t: "Gmail is read-only & opt-in", d: "Email is classified on your device — no content ever leaves your browser." },
];
---
<div class="rounded-2xl border border-emerald-100 bg-emerald-50/60 p-8">
  <div class="flex items-center gap-2 text-green">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1 3 5v6c0 5 3.8 9.7 9 11 5.2-1.3 9-6 9-11V5l-9-4Zm-1 15-4-4 1.4-1.4L11 13.2l4.6-4.6L17 10l-6 6Z"/></svg>
    <span class="text-xs font-bold uppercase tracking-wider">Private by default</span>
  </div>
  <h2 class="mt-3 font-display text-2xl font-extrabold text-slate-900 sm:text-3xl">
    Your job hunt stays yours.
  </h2>
  <div class="mt-6 grid gap-5 sm:grid-cols-3">
    {
      points.map((p) => (
        <div>
          <h3 class="font-semibold text-slate-900">{p.t}</h3>
          <p class="mt-1 text-sm leading-relaxed text-slate-600">{p.d}</p>
        </div>
      ))
    }
  </div>
  <a href={withBase("/privacy")} class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-green hover:underline">
    Read the privacy policy
    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.3 4.3a1 1 0 0 1 1.4 0l5 5a1 1 0 0 1 0 1.4l-5 5a1 1 0 1 1-1.4-1.4L11.6 10 7.3 5.7a1 1 0 0 1 0-1.4Z" clip-rule="evenodd"/></svg>
  </a>
</div>
